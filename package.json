{
  "name": "vue3-monaco-editor",
  "version": "0.2.6",
  "description": "A lightweight Monaco Editor component library for Vue 3.",
  "main": "dist/vue3-monaco-editor.umd.js",
  "module": "dist/vue3-monaco-editor.es.js",
  "style": "dist/vue3-monaco-editor.css",
  "types": "./types/vue3-monaco-editor.d.ts",
  "typings": "./types/vue3-monaco-editor.d.ts",
  "files": [
    "dist",
    "types",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./types/vue3-monaco-editor.d.ts",
      "import": "./dist/vue3-monaco-editor.es.js",
      "default": "./dist/vue3-monaco-editor.umd.js"
    },
    "./style.css": "./dist/vue3-monaco-editor.css",
    "./dist/vue3-monaco-editor.css": "./dist/vue3-monaco-editor.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "rollup -c",
    "check": "vue-tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "link": "npm link && npm link vue3-monaco-editor",
    "prepare": "husky",
    "preview": "vite preview",
    "serve": "vite"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,less,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "vue3",
    "sql",
    "monaco",
    "monaco-editor",
    "editor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcy960815/vue3-monaco-editor.git"
  },
  "author": {
    "name": "xcy960815",
    "email": "18763006837@163.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/xcy960815/vue3-monaco-editor/issues"
  },
  "homepage": "https://github.com/xcy960815/vue3-monaco-editor#readme",
  "peerDependencies": {
    "monaco-editor": "^0.27.0",
    "vue": "^3.2.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/compiler-sfc": "^3.5.17",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "globals": "^15.8.0",
    "husky": "^9.1.4",
    "less": "^4.1.3",
    "lint-staged": "^15.2.7",
    "monaco-editor": "0.27.0",
    "prettier": "^3.3.3",
    "rollup": "^4.44.1",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.0.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^5.4.10",
    "vitepress": "^1.3.4",
    "vue": "^3.5.17",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
